[Unit]
Description=Defoex InfraTech Flask API
After=network.target postgresql.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/defoex-backend
Environment="PATH=/home/ubuntu/defoex-backend/venv/bin"
EnvironmentFile=-/home/ubuntu/defoex-backend/.env
ExecStart=/home/ubuntu/defoex-backend/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
